@inherits LayoutComponentBase

<div class="mip-layout">
    <nav class="mip-sidebar">
        <div class="mip-logo">
            <span class="mip-logo-title">miProcurement</span>
            <span class="mip-logo-sub">K-12 Food Service ERP</span>
        </div>
        <ul class="mip-nav">
            <li><NavLink href="" Match="NavLinkMatch.All" class="mip-nav-link"><span class="mip-icon">⊞</span> Dashboard</NavLink></li>
            <li><NavLink href="purchase-orders" class="mip-nav-link"><span class="mip-icon">📋</span> Purchase Orders</NavLink></li>
            <li><NavLink href="inventory" class="mip-nav-link"><span class="mip-icon">📦</span> Inventory</NavLink></li>
            <li><NavLink href="commodities" class="mip-nav-link"><span class="mip-icon">🌾</span> Commodities</NavLink></li>
