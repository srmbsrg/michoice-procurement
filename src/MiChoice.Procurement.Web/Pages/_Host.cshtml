@page "/"
@namespace MiChoice.Procurement.Web.Pages
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>miProcurement — MiChoice</title>
    <base href="~/" />
    <link href="css/app.css" rel="stylesheet" />
    <link href="MiChoice.Procurement.Web.styles.css" rel="stylesheet" />
</head>
<body>
    <component type="typeof(MiChoice.Procurement.Web.App)" render-mode="ServerPrerendered" />
    <div id="blazor-error-ui">
        <environment include="Staging,Production">An error has occurred.</environment>
        <environment include="Development">An unhandled exception has occurred. See browser dev tools for details.</environment>
        <a href="" class="reload">Reload</a>
        <a class="dismiss">🗙</a>
    </div>
    <script src="_framework/blazor.server.js"></script>
</body>
</html>
